# Server Configuration
PORT=3001
NODE_ENV=development

# Google Custom Search API
GOOGLE_SEARCH_API_KEY=your_google_search_api_key_here
GOOGLE_SEARCH_ENGINE_ID=your_search_engine_id_here

# Google Gemini API (for text-to-image and image-to-image)
GOOGLE_GEMINI_API_KEY=your_gemini_api_key_here

# CORS Configuration
CLIENT_URL=http://localhost:3000

# Google Cloud Project Configuration
GCP_PROJECT_ID=your_gcp_project_id_here

# Google Cloud Storage (GCS) Configuration
GCS_BUCKET=your_gcs_bucket_name_here
ASSET_PUBLIC=public

# Google Cloud Billing Export to BigQuery Configuration
BILLING_BQ_PROJECT_ID=your_billing_bq_project_id_here
BILLING_BQ_DATASET=billing_export
BILLING_BQ_TABLE=gcp_billing_export_v1_XXXXXX
BILLING_CREDIT_LIMIT_USD=200
